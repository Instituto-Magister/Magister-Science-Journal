/* --- FUENTES --- */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Roboto:wght@300;400;500;700&display=swap');

/* --- ESTILOS GENERALES DEL BODY Y BACKGROUND --- */
body {
background: white;
font-family: 'Inter', sans-serif;
color: black;
margin: 0;
}

/* ======================================
   CONTENEDOR DEL TÍTULO Y MENÚ PC
====================================== */
.site-container {
position: relative;
top: 0;
left: 0;  
width: 100%;
box-sizing: border-box;
background: white !important; 
margin: 0;
padding: 20px 40px;
display: flex;
align-items: center;
justify-content: space-between;
}
/* --- TÍTULO --- */
.site-title {
font-family: 'Inter', sans-serif;
font-size: 1.5rem; 
color: #0C2A1F !important;
text-align: left;
font-weight: bold;
line-height: 1; 
margin: 0;
padding: 0;
flex-shrink: 0;
}
.site-container { display: flex; }
.site-container-mobile { display: none; }
.site-title { display: block; }
.site-title-mobile { display: none; }
/* ======================================
   TÍTULO DE LA PÁGINA MÓVIL
====================================== */
@media (max-width: 768px) {
.site-container-mobile { 
position: relative;
top: 0;
left: 0;  
width: 100%;
box-sizing: border-box;
background: white !important;    
margin: 0;
padding: 15px 20px;
display: flex;
align-items: center;
justify-content: space-between;
}
.site-title-mobile {
font-family: 'Inter', sans-serif;
font-size: 1.2rem;
color: black !important;
text-align: left; 
font-weight: bold;
margin: 0;
padding: 0;
}
.site-container { display: none; }
.site-container-mobile { display: flex; }   
.site-title { display: none; }
.site-title-mobile { display: block; }
}

/* ======================================
   MENÚ Y SUBMENUS PC
====================================== */
nav {
text-align: center;
flex-grow: 1;
}
.menu {
list-style: none;
display: flex;
flex-wrap: wrap;
justify-content: center;
gap: 30px;
margin: 0 auto;
padding: 0;
}
.menu li {
position: relative;
}
/* --- BOTONES DEL MENÚ (SIN RECUADROS) --- */
.menu-button {
position: relative;
display: block;
background: transparent !important;
border: none !important;
border-radius: 0;
font-family: 'Inter', sans-serif;
font-size: 1rem;
text-decoration: none;
text-transform: uppercase;
margin: 0;
padding: 8px 0;
cursor: pointer;
transition: all 0.3s ease;
color: #0C2A1F !important;
box-shadow: none !important;
}

/* ELIMINAR PUNTO LED */
.menu-button::after {
display: none;
}

/* HOVER - SUBRAYADO */
.menu-button:hover {
background: transparent !important;
color: black !important;
transform: none;
box-shadow: none !important;
text-shadow: none !important;
}

/* SUBRAYADO ANIMADO */
.menu-button::before {
content: '';
position: absolute;
bottom: 0;
left: 0;
width: 0;
height: 2px;
background-color: black;
transition: width 0.3s ease;
}

.menu-button:hover::before {
width: 100%;
}

/* --- SUBMENÚS DESPLEGABLES --- */
.submenu {
position: absolute; 
display: none;
top: 100%;
left: 50%;
transform: translateX(-50%);
list-style: none;
background: white !important;
z-index: 1000;
border: 2px solid black !important;
margin: 0;
padding: 0;
min-width: 250px;
}
.menu li:hover .submenu {
display: block;
}
/* --- ELEMENTOS DEL SUBMENÚ --- */
.submenu li {
position: relative;
overflow: hidden;
}
.submenu-button {
display: block;
width: 100%;
text-align: left;
background: transparent;
border: none;
color: black !important;
padding: 12px 15px;
font-size: 0.9rem;
font-family: 'Inter', sans-serif; /* Agregué comillas */
text-transform: capitalize;
white-space: nowrap;
text-decoration: none;
transition: all 0.3s ease;
font-weight: 600;
}
.submenu-button:hover {
background: rgba(0, 0, 0, 0.1) !important;
color: black !important;
padding-left: 20px;
}
/* --- LÍNEA NEGRA ANIMADA --- */
.submenu li::before {
content: '';
position: absolute;
left: 0;
bottom: 0;
width: 100%;
height: 3px;
background-color: black !important;
transform: scaleX(0);
transform-origin: left;
transition: transform 0.3s ease;
}
.submenu li:hover::before {
transform: scaleX(1);
}
/* --- Separadores entre items --- */
.submenu li:not(:last-child) {
border-bottom: 1px solid black !important;
}

/* ======================================
   MENÚ HAMBURGUESA MOVIL
====================================== */
.menu-mobile { display: none; }
.menu-mobile-hamburger-button {
position: relative;
display: flex;
flex-direction: column;
justify-content: center;
align-items: center;
z-index: 1001;
background: transparent !important;
border-radius: 8px;
padding: 12px 10px;
gap: 5px;
cursor: pointer;
transition: all 0.3s ease;
border: 2px solid #0C2A1F !important;
}
/* LAS RAYAS DEL BOTÓN */
.menu-mobile-hamburger-button span {
display: block;
width: 25px;
height: 3px;
background: #0C2A1F !important;
transition: all 0.3s ease;
}
/* HOVER - Sin efectos especiales */
.menu-mobile-hamburger-button:hover {
background: rgba(12, 42, 31, 0.1) !important;
}
/* OVERLAY - Color especificado */
.menu-mobile-hamburger-overlay {
position: fixed;
z-index: 1000; 
width: 100%;
height: 100%;
top: 0;
left: 0;
background: #0C2A1F !important;
display: none;
}
.menu-mobile-hamburger-overlay.active {
display: block;
}
.menu-mobile-hamburger-overlay ul {
list-style: none;
padding: 0;
margin: 0;
height: 100%;
display: flex;
flex-direction: column;
justify-content: center;
align-items: center;
}
/* Elementos del menú */
.menu-mobile-hamburger-overlay li {
text-align: center;
border-bottom: 1px solid rgba(255, 255, 255, 0.2) !important;
padding: 12px 0;
width: 80%;
max-width: 300px;
}
.menu-mobile-hamburger-overlay li:last-child {
border-bottom: none !important;
}
.menu-mobile-hamburger-overlay a {
font-family: 'Inter', sans-serif;
font-size: 1rem;
text-decoration: none; 
text-transform: uppercase;
padding: 0 20px;
display: block;
color: #FFFFFF !important;
letter-spacing: 1px;
}
/* Efecto hover para enlaces */
.menu-mobile-hamburger-overlay a:hover {
opacity: 0.8;
}
/* --- MEDIA QUERY PARA MÓVIL --- */
@media (max-width: 768px) {
.menu-mobile {
display: block;
position: fixed;
top: 15px;
right: 15px;
z-index: 1000;
}
nav {
display: none !important;
}
}













/* ======================================
   INICIO BANNER PC
====================================== */
.inicio-banner {
position: relative;
z-index: 1;   
width: 100%;
box-sizing: border-box;
height: 50vh;
overflow: hidden;
display: flex;
justify-content: center;
align-items: center;
background: #000000 !important;
margin: 0px auto !important; 
}
.inicio-banner img {
position: absolute;
z-index: 1;
width: 100%;
height: 100%;
object-fit: cover;
background: #000000 !important;
}
/* CONTROL */
.inicio-banner { display: flex; }
.inicio-banner-mobile { display: none; }
/* ======================================
   MOVIL RESPONSIVE: FILM
====================================== */
@media (max-width: 768px) {  
.inicio-banner-mobile {
position: relative;
z-index: 1; 
width: 100%;
height: 500px;
box-sizing: border-box;   
overflow: hidden;  
display: flex;
justify-content: center;
align-items: center;   
background: #000000 !important;
margin: 0px auto;
}
.inicio-banner-mobile-1 img {
position: absolute;
z-index: 1;    
width: 100%;
height: 100%;
object-fit: cover;
background: #000000 !important;   
}
/* CONTROL */
.inicio-banner { display: none; }
.inicio-banner-mobile { display: flex; }
}


/* ======================================
   INICIO
====================================== */
.inicio-container {
position: relative;
width: 100%;
box-sizing: border-box;
background: #0A1128 !important;
border-radius: 0px;
margin: 0px auto;
padding: 30px;
}
.inicio-title {
position: relative;
z-index: 2;
display: block;
font-family: 'Inter', sans-serif;
font-size: 2rem;
color: white !important;
text-decoration: none;
text-transform: uppercase;
text-align: center;   
line-height: 1.6;
margin: 0 0 16px 0;
}
.inicio-title a {
color: white !important;
text-decoration: none;
}

/* CONTROL */
.inicio-container { display: block; }
.segundoinicio-container-mobile { display: none; }

/* ======================================
   MOVIL RESPONSIVE: SEGUNDOINICIO
====================================== */
@media (max-width: 768px) {
.segundoinicio-container-mobile {
position: relative;
width: 100%;
box-sizing: border-box;
background: #0A1128 !important;
border-radius: 0px;
margin: 0px auto;
padding: 20px;   
}
.segundoinicio-title-mobile {
position: relative;
z-index: 2;
display: block;
font-family: 'Inter', sans-serif;
font-size: 1.5rem;
color: white !important;
text-decoration: none;
text-transform: uppercase;
text-align: center;   
margin: 0 0 10px 0;   
}
.segundoinicio-title-mobile a {
color: white !important;
text-decoration: none;
}

/* CONTROL */
.inicio-container { display: none; }
.segundoinicio-container-mobile { display: block; }
}

/* ======================================
   PROPOSITO
====================================== */
.proposito-container {
position: relative;
width: 100%;
box-sizing: border-box;
background: #FFFFFF !important;
border-radius: 0px;
margin: 0px auto;
padding: 30px;
}
.proposito-title {
position: relative;
z-index: 2;
display: block;
font-family: 'Inter', sans-serif;
font-size: 2rem;
color: #0C2A1F !important;
text-decoration: none;
text-transform: uppercase;
text-align: center;   
margin: 0 0 10px 0;
}
.proposito-title a {
color: #0C2A1F !important;
text-decoration: none;
}
/* CONTENEDOR: COLUMNAS */
.proposito-columns {
position: relative;
z-index: 2;
}
/* CONTENEDOR: GRID DE 3 */
.proposito-columns-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 20px;
margin: 0px;
}
/* CONTENEDOR: INFORMACIÓN */
.proposito-columns-grid-information {
width: 100%;
min-width: 0;
margin: 0px;
}
.proposito-columns-grid-information-subtitle {
font-family: 'Inter', sans-serif;
font-size: 1.5rem;
color: #0A1128 !important;
text-decoration: none;
text-align: center;   
line-height: 1.4;
margin: 0 0 10px 0;
font-weight: bold;
}
.proposito-columns-grid-information-text {
font-family: 'Inter', sans-serif;
font-size: 1rem;
color: #000000 !important;
text-decoration: none;
text-align: justify;   
line-height: 1.5;
margin: 0 0 10px 0;
word-break: break-word;
overflow-wrap: break-word;
}
/* CONTENEDOR: IMAGEN */
.proposito-columns-grid-information-image {
width: 100%;
min-width: 0;
margin: 0 0 15px 0;
}
.proposito-columns-grid-information-image img {
width: 100%;
height: auto;
display: block;
border-radius: 0px;
}
/* CONTENEDOR: BOTÓN */
.proposito-columns-grid-information-text-button {
width: 100%;
box-sizing: border-box;   
display: flex;
justify-content: center;
margin: 0px 0 10px 0;
}
.proposito-columns-grid-information-text-button-pdf {
display: flex;
justify-content: center;   
background-color: #0C2A1F !important;
border-radius: 0px; 
font-family: 'Inter', sans-serif;
font-size: 1.2rem;
color: white !important;
text-decoration: none;
text-transform: uppercase;   
font-weight: bold;
margin: 0px;   
padding: 10px 20px;
border: none;
cursor: pointer;
transition: transform 0.3s ease, background-color 0.3s ease;
}
.proposito-columns-grid-information-text-button-pdf:hover {
transform: scale(1.05);
}
/* CONTROL */
.proposito-container { display: block; }
.proposito-container-mobile { display: none; }
/* ======================================
   MOVIL RESPONSIVE: PROPOSITO
====================================== */
@media (max-width: 768px) {
.proposito-container-mobile {
position: relative;
width: 100%;
box-sizing: border-box;
background: #FFFFFF !important;
border-radius: 0px;
margin: 0px auto;
padding: 20px;   
}
.proposito-title-mobile {
position: relative;
z-index: 2;
display: block;
font-family: 'Inter', sans-serif;
font-size: 1.5rem;
color: #0C2A1F !important;
text-decoration: none;
text-transform: uppercase;
text-align: center;   
margin: 0 0 10px 0;   
}
.proposito-title-mobile a {
color: #0C2A1F !important;
text-decoration: none;
}
/* CONTENEDOR: INFORMACIÓN */
.proposito-information-mobile {
width: 100%;
min-width: 0;
margin: 0px;
}
.proposito-information-subtitle-mobile {
font-family: 'Inter', sans-serif;
font-size: 1.5rem;
color: #0A1128 !important;
text-decoration: none;
text-align: center;   
line-height: 1.4;
margin: 0 0 10px 0;
font-weight: bold;
}
.proposito-information-text-mobile {
font-family: 'Inter', sans-serif;
font-size: 1rem;
color: #000000 !important;
text-decoration: none;
text-align: justify;   
line-height: 1.5;
margin: 0 0 10px 0;
word-break: break-word;
overflow-wrap: break-word;
}
/* CONTENEDOR: IMAGEN */
.proposito-information-image-mobile {
width: 100%;
min-width: 0;
margin: 0 0 15px 0;
}
.proposito-information-image-mobile img {
width: 100%;
height: auto;
display: block;
border-radius: 0px;
}
/* CONTENEDOR: BOTÓN */
.proposito-information-text-button-mobile {
width: 100%;
box-sizing: border-box;   
display: flex;
justify-content: center;
margin: 0px 0 10px 0;
}
.proposito-information-text-button-pdf-mobile {
display: flex;
justify-content: center;   
background-color: #0C2A1F !important;
border-radius: 0px; 
font-family: 'Inter', sans-serif;
font-size: 1.2rem;
color: white !important;
text-decoration: none;
text-transform: uppercase;   
font-weight: bold;
margin: 0px;   
padding: 10px 20px;
border: none;
cursor: pointer;
transition: transform 0.3s ease, background-color 0.3s ease;
}
.proposito-information-text-button-pdf-mobile:hover {
transform: scale(1.05);
}
/* CONTROL */
.proposito-container { display: none; }
.proposito-container-mobile { display: block; }
}









/* ======================================
   FOOTER PC
====================================== */
.footer {
position: relative;
width: 100%;
box-sizing: border-box; 
background: #0A1128 !important;
margin-top: auto;   
padding: 30px;
}
/* CONTENEDOR: NOMBRE Y COPYRIGHT */
.footer-brand {
width: 100%;
box-sizing: border-box;    
display: flex;
flex-direction: column;
align-items: center;
}
.footer-brand-name {
font-family: 'Inter', sans-serif;
font-size: 1rem;
color: #FFFFFF !important;
text-decoration: none;
text-align: center;
margin: 0 0 10px 0;
font-weight: bold;
}
.footer-brand-allrightreserved {
font-family: 'Inter', sans-serif;
font-size: 0.8rem;
color: #FFFFFF !important;
text-decoration: none;
line-height: 1.5;
margin: 0 0 10px 0;   
}
/* CONTENEDOR: LINK - 3 COLUMNAS */
.footer-link {
width: 100%;
box-sizing: border-box;   
display: grid;
grid-template-columns: repeat(3, 1fr);
align-items: center;
margin: 0 0 30px 0;
text-align: center;
}
.footer-link-termsandconditions {
grid-column: 1;
justify-self: center;
}
.footer-link-privacypolicy {
grid-column: 2;
justify-self: center;
}
.footer-link-mapadelsitio {
grid-column: 3;
justify-self: center;
}
.footer-link-termsandconditions a,
.footer-link-privacypolicy a,
.footer-link-mapadelsitio a {
position: relative;
z-index: 1;
font-family: 'Inter', sans-serif;
font-size: 0.8rem;
color: #FFFFFF !important;
text-decoration: none;
line-height: 1.5;  
margin: 0;
padding: 0 15px; /* Espaciado lateral */
transition: all 0.3s ease;
display: inline-block;
}
.footer-link-termsandconditions a:hover,
.footer-link-privacypolicy a:hover,
.footer-link-mapadelsitio a:hover {
color: #87CEEB !important;
text-decoration: underline;
}
/* CONTENEDOR: REDES SOCIALES - 2 COLUMNAS */
.footer-socialmedia {
position: relative;
z-index: 1;
display: grid;
grid-template-columns: repeat(2, 1fr);
align-items: center;   
width: 100%;
margin: 0 0 20px 0;
text-align: center;
}
/* WhatsApp - Primera columna */
.footer-socialmedia a:first-child {
grid-column: 1;
justify-self: center;
}
/* Email - Segunda columna */
.footer-socialmedia a:last-child {
grid-column: 2;
justify-self: center;
}
.footer-socialmedia-icon {
width: 25px;
height: 25px;
color: #FFFFFF !important;
transition: all 0.3s ease;
}
.footer-socialmedia-icon:hover {
transform: scale(1.2);
color: #87CEEB !important;
}
.footer-contact-info {
margin-left: 10px;
font-family: 'Inter', sans-serif;
font-size: 0.8rem;
color: #FFFFFF !important;
text-decoration: none;
}
.footer-socialmedia a:hover .footer-contact-info {
color: #87CEEB !important;
}
/* CONTROL */
.footer { display: block; }
.footer-mobile { display: none; }
